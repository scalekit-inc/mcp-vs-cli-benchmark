# =============================================================================
# MCP vs CLI Benchmark — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Model Provider API Keys ------------------------------------------------
# Set the key(s) for the provider you want to benchmark.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# --- Benchmark Configuration ------------------------------------------------
# Model to use for benchmark runs (LiteLLM format).
# See https://docs.litellm.ai/docs/providers for supported identifiers.
# Examples:
#   anthropic/claude-sonnet-4-20250514
#   openai/gpt-4o
#   gemini/gemini-2.5-pro
BENCHMARK_MODEL=anthropic/claude-sonnet-4-20250514

# Model used for LLM-as-judge correctness evaluation.
JUDGE_MODEL=anthropic/claude-opus-4-20250514

# --- Service Credentials ----------------------------------------------------
# GitHub personal access token (requires repo read scope).
GITHUB_TOKEN=ghp_...

# Target repository for GitHub benchmark tasks (org/repo format).
BENCHMARK_REPO=your-org/mcp-vs-cli-benchmark-data

# URL of the MCP GitHub server (leave empty to use default local server).
MCP_GITHUB_SERVER_URL=

# PostgreSQL connection string (for database benchmark tasks).
POSTGRES_URL=postgresql://bench:bench@localhost:5432/benchmark

# Google service account JSON (for Google Workspace tasks, if applicable).
GOOGLE_SERVICE_ACCOUNT_JSON=
